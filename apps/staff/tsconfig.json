{
  "extends": "../../packages/config/tsconfig/lib.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "next.config.ts", "src", "test", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
