{
  "$schema": "https://biomejs.dev/schemas/2.1.2/schema.json",
  "root": false,
  "extends": "//",
  "linter": {
    "rules": {
      "a11y": {
        "useButtonType": "off",
        "noSvgWithoutTitle": "off",
        "useSemanticElements": "off"
      },
      "performance": {
        "noImgElement": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "off"
      },
      "complexity": {
        "noUselessFragments": "off"
      },
      "style": {
        "noDescendingSpecificity": "off"
      }
    }
  }
}
