{
  "name": "@boca/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "node --env-file-if-exists=../../.env dist/main.js",
    "start:worker": "node --env-file-if-exists=../../.env dist/main.worker.js",
    "seed:dev": "tsx --env-file-if-exists=../../.env scripts/seed-dev.ts",
    "seed:desaga": "tsx --env-file-if-exists=../../.env scripts/seed-desaga.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@boca/config": "workspace:*",
    "@boca/contracts": "workspace:*",
    "@boca/db": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.3",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/nest": "^3.52.1",
    "argon2": "^0.41.1",
    "bullmq": "^5.80.2",
    "ioredis": "^5.10.1",
    "openai": "^6.48.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@swc/core": "^1.10.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  }
}
