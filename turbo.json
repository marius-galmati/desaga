{
  "$schema": "https://turborepo.com/schema.json",
  "boundaries": {
    "tags": {
      "db-layer": {
        "dependents": {
          "allow": ["api"]
        }
      }
    }
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
