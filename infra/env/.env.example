# Copy to the repo root as `.env` for local development.
# Prod: a single /srv/boca/.env (root-owned, chmod 600) referenced via
# env_file; secrets rotated per runbook. Never commit real values.

NODE_ENV=development
PORT=3000

# Dev compose superuser (bypasses RLS!). For RLS-enforced runs, connect with a
# LOGIN user granted the boca_app role instead.
DATABASE_URL=postgres://boca:boca@localhost:5432/boca
# Background jobs connect with a boca_worker-role user in prod; dev falls back
# to DATABASE_URL when unset.
WORKER_DATABASE_URL=postgres://boca:boca@localhost:5432/boca

REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible). DB stores object keys only.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=boca
S3_SECRET_KEY=boca-dev-password
S3_BUCKET=boca-media

# Auth (access JWT; refresh tokens are opaque + hashed in DB)
JWT_ACCESS_SECRET=dev-only-change-me-32-chars-minimum
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# AI scoring — used ONLY by the ai-score BullMQ processor, never in the HTTP path.
ANTHROPIC_API_KEY=sk-ant-replace-me
