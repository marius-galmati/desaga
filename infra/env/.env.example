# Copy to the repo root as `.env` for local development.
# Prod: a single /srv/boca/.env (root-owned, chmod 600) referenced via
# env_file; secrets rotated per runbook. Never commit real values.
#
# Compose port overrides: when a host service already owns a default port,
# start the dev stack with the BOCA_*_PORT variables exported in the SHELL
# (docker compose reads them from the environment, not from this file), e.g.:
#   BOCA_PG_PORT=55432 BOCA_REDIS_PORT=56379 BOCA_MINIO_PORT=59000 \
#   BOCA_MINIO_CONSOLE_PORT=59001 \
#   docker compose -f infra/compose/docker-compose.dev.yml up -d
# ...and keep DATABASE_URL/REDIS_URL/S3_ENDPOINT below pointing at those ports.

NODE_ENV=development
PORT=3000

# Dev compose superuser (bypasses RLS!). Used by MIGRATIONS and SEEDS, which
# must bypass RLS to bootstrap tenants and own DDL. Host port = BOCA_PG_PORT.
DATABASE_URL=postgres://boca:boca@localhost:5432/boca
# RLS-ENFORCED runtime roles: the app pool uses APP_DATABASE_URL (a LOGIN user
# granted boca_app) and background jobs use WORKER_DATABASE_URL (granted
# boca_worker) so row-level security is exercised in dev exactly like prod.
# Create the roles once: see infra/db/dev-roles.sql. Leave APP_DATABASE_URL
# unset to fall back to DATABASE_URL (superuser, RLS bypassed).
APP_DATABASE_URL=postgres://boca_app_login:boca-app-dev@localhost:5432/boca
WORKER_DATABASE_URL=postgres://boca_worker_login:boca-worker-dev@localhost:5432/boca

# BullMQ "ai-score" queue. Host port = BOCA_REDIS_PORT.
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible). DB stores object keys only. Host port = BOCA_MINIO_PORT
# (console = BOCA_MINIO_CONSOLE_PORT).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=boca
S3_SECRET_KEY=boca-dev-password
S3_BUCKET=boca-media

# Auth (access JWT; refresh tokens are opaque + hashed in DB)
JWT_ACCESS_SECRET=dev-only-change-me-32-chars-minimum
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# AI scoring — used ONLY by the ai-score BullMQ processor, never in the HTTP path.
# Leave ANTHROPIC_API_KEY empty (or set EVAL_MOCK=true) to run the deterministic
# MOCK evaluator; the whole pipeline works end-to-end without the real key.
ANTHROPIC_API_KEY=
# Pinned model id (exact string, never a floating alias).
EVAL_MODEL=claude-sonnet-5
EVAL_MOCK=false
