# =============================================================================
# Boca production environment — for the Dokploy Compose deployment.
#
# In Dokploy: paste these into the deployment's Environment tab and replace every
# placeholder with a real value. Do NOT commit real secrets. Compose substitutes
# ${VAR} in infra/compose/docker-compose.prod.yml from this environment.
#
# Generate strong secrets, e.g.:  openssl rand -hex 32   (or -base64 24)
# =============================================================================

# Root domain that all subdomains hang off of. The stack serves:
#   admin.${ROOT_DOMAIN}  -> admin (Next)
#   demo.${ROOT_DOMAIN}   -> showcase (Next, the pitch prototype)
#   media.${ROOT_DOMAIN}  -> MinIO S3 API (presigned image URLs)
# Create DNS A-records for all three (see the deploy notes).
ROOT_DOMAIN=desaga.ro

# OPTIONAL host overrides. By default routing uses the admin./demo./media.
# subdomains of ROOT_DOMAIN above. If you can't create those subdomains yet
# (e.g. a provider-issued host like desaga.hostero.ro that can't be nested),
# set the exact Traefik hostname per service here. Each falls back to its
# admin./demo./media. subdomain when left unset. MEDIA_HOST also drives the
# public endpoint that presigned image URLs are signed against, so images only
# load if MEDIA_HOST resolves to MinIO. For a quick single-host test, set just
# ADMIN_HOST (the panel loads; photos stay broken until MEDIA_HOST resolves).
#   ADMIN_HOST=desaga.hostero.ro
#   DEMO_HOST=demo-desaga.hostero.ro
#   MEDIA_HOST=media-desaga.hostero.ro

# --- Postgres ----------------------------------------------------------------
# Superuser password for the `boca` role (used by Postgres itself and ONLY by
# the one-shot migrate job). Not exposed to the app/worker containers.
POSTGRES_PASSWORD=change-me-postgres-superuser

# RLS-enforced runtime LOGIN roles, created by the migrate job from these values.
# The app connects as boca_app_login, background jobs as boca_worker_login.
APP_DB_PASSWORD=change-me-app-role-password
WORKER_DB_PASSWORD=change-me-worker-role-password

# --- Object storage (MinIO / S3) ---------------------------------------------
# Double as the MinIO root credentials AND the app's S3 access keys.
S3_ACCESS_KEY=change-me-s3-access-key
S3_SECRET_KEY=change-me-s3-secret-key
# Bucket auto-created by the minio-init job.
S3_BUCKET=boca-media

# --- Auth --------------------------------------------------------------------
# Access-token signing secret. MUST be >= 16 chars (app boot validation); use 32+.
JWT_ACCESS_SECRET=change-me-32-char-minimum-access-secret

# --- AI plating evaluation ---------------------------------------------------
# Real Anthropic key. Leave EMPTY to force the deterministic MOCK evaluator
# (the whole pipeline still runs end-to-end). Compose sets EVAL_MOCK=false, so
# an empty key here => the app auto-selects mock mode anyway.
ANTHROPIC_API_KEY=
# Pinned model id — exact string, never a floating alias.
EVAL_MODEL=claude-sonnet-5

# --- First-run bootstrap (the one-off `seed` service, profile: seed) ----------
# Used ONLY when you run the `seed` service once after the first deploy to create
# the Desaga tenant + menu and your admin login. Choose a real, strong password.
SEED_ADMIN_EMAIL=admin@desaga.ro
SEED_ADMIN_PASSWORD=change-me-strong-admin-password
